{
  "name": "rmachine",
  "version": "1.0.0-alpha.11",
  "description": "Command-line interface for R-Machine — scaffolding, diagnostics, and LLM-agent skill generation.",
  "author": "Sergio Turolla <hello@codecarvings.com>",
  "license": "AGPL-3.0-only",
  "type": "module",
  "homepage": "https://r-machine.codecarvings.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecarvings/r-machine.git"
  },
  "bugs": "https://github.com/codecarvings/r-machine/issues",
  "keywords": [
    "r-machine",
    "cli",
    "typescript",
    "i18n",
    "llm-friendly",
    "ai-friendly",
    "skill",
    "scaffolding"
  ],
  "sideEffects": false,
  "files": [
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.d.ts",
    "**/*.d.mts",
    "**/*.d.cts"
  ],
  "main": "./lib/index.cjs",
  "types": "./lib/index.d.cts",
  "module": "./lib/index.js",
  "bin": "./bin.cjs",
  "zshy": {
    "bin": "./src/bin.ts",
    "exports": {
      ".": "./src/lib/index.ts"
    },
    "conditions": {
      "@r-machine/source": "src"
    }
  },
  "exports": {
    ".": {
      "@r-machine/source": "./src/lib/index.ts",
      "types": "./lib/index.d.cts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "imports": {
    "#rmachine": {
      "@r-machine/source": "./src/lib/index.ts",
      "types": "./lib/index.d.cts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "clean": "git clean -xdf . -e node_modules",
    "sync-version": "node -e \"require('fs').writeFileSync('src/lib/version.ts','// AUTO-GENERATED by pnpm sync-version — do not edit.\\nexport const CLI_VERSION = '+JSON.stringify(require('./package.json').version)+';\\n')\"",
    "prebuild": "pnpm sync-version",
    "build": "zshy --project tsconfig.build.json",
    "postbuild": "pnpm biome check --write .",
    "pretest": "pnpm sync-version",
    "test": "pnpm vitest run --typecheck",
    "test:watch": "pnpm vitest watch --typecheck",
    "predev": "pnpm sync-version",
    "dev": "tsx --conditions @r-machine/source src/bin.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "citty": "^0.2.2",
    "picocolors": "^1.1.1"
  }
}
