{
  "name": "@r-machine/testing",
  "version": "1.0.0-alpha.11",
  "description": "Testing utilities for R-Machine — helpers for testing typed resource access in your applications",
  "author": "Sergio Turolla <hello@codecarvings.com>",
  "license": "AGPL-3.0-only",
  "type": "module",
  "homepage": "https://r-machine.codecarvings.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecarvings/r-machine.git"
  },
  "bugs": "https://github.com/codecarvings/r-machine/issues",
  "keywords": [
    "typescript",
    "testing",
    "test",
    "mock",
    "r-machine",
    "type-safe",
    "typesafe",
    "i18n",
    "dependency-injection",
    "state-management",
    "reactive",
    "vitest",
    "jest",
    "react-testing-library",
    "shell",
    "gear",
    "plug",
    "ai-friendly"
  ],
  "sideEffects": false,
  "files": [
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.d.ts",
    "**/*.d.mts",
    "**/*.d.cts"
  ],
  "main": "./lib/index.cjs",
  "types": "./lib/index.d.cts",
  "module": "./lib/index.js",
  "zshy": {
    "exports": {
      ".": "./src/lib/index.ts"
    },
    "conditions": {
      "@r-machine/source": "src"
    }
  },
  "exports": {
    ".": {
      "@r-machine/source": "./src/lib/index.ts",
      "types": "./lib/index.d.cts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "imports": {
    "#r-machine/testing": {
      "@r-machine/source": "./src/lib/index.ts",
      "types": "./lib/index.d.cts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "clean": "git clean -xdf . -e node_modules",
    "build": "zshy --project tsconfig.build.json",
    "postbuild": "pnpm biome check --write .",
    "test": "pnpm vitest run --typecheck",
    "test:watch": "pnpm vitest watch --typecheck"
  },
  "peerDependencies": {
    "r-machine": "workspace:*"
  }
}
