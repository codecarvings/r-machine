{
  "name": "r-machine",
  "version": "1.0.0-alpha.11",
  "description": "R-Machine — typed resource layer with structural uniformity under change for TypeScript.",
  "author": "Sergio Turolla <hello@codecarvings.com>",
  "license": "AGPL-3.0-only",
  "type": "module",
  "homepage": "https://rmachine.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecarvings/r-machine.git"
  },
  "bugs": "https://github.com/codecarvings/r-machine/issues",
  "keywords": [
    "rmachine",
    "typescript",
    "type-safe",
    "typesafe",
    "uniformity-under-change",
    "refactor-safe",
    "resource-layer",
    "i18n",
    "internationalization",
    "dependency-injection",
    "state-management",
    "reactive",
    "testable",
    "ai-friendly",
    "llm-friendly",
    "react",
    "nextjs",
    "no-codegen",
    "intellisense",
    "shell",
    "gear",
    "plug"
  ],
  "sideEffects": false,
  "files": [
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.d.ts",
    "**/*.d.mts",
    "**/*.d.cts"
  ],
  "main": "./lib/index.cjs",
  "types": "./lib/index.d.cts",
  "module": "./lib/index.js",
  "zshy": {
    "exports": {
      "./errors": "./src/errors/index.ts",
      "./locale": "./src/locale/index.ts",
      "./core": "./src/core/index.ts",
      ".": "./src/lib/index.ts",
      "./strategy": "./src/strategy/index.ts",
      "./strategy/web": "./src/strategy/web/index.ts"
    },
    "conditions": {
      "@r-machine/source": "src"
    }
  },
  "exports": {
    "./errors": {
      "@r-machine/source": "./src/errors/index.ts",
      "types": "./errors/index.d.cts",
      "import": "./errors/index.js",
      "require": "./errors/index.cjs"
    },
    "./locale": {
      "@r-machine/source": "./src/locale/index.ts",
      "types": "./locale/index.d.cts",
      "import": "./locale/index.js",
      "require": "./locale/index.cjs"
    },
    "./core": {
      "@r-machine/source": "./src/core/index.ts",
      "types": "./core/index.d.cts",
      "import": "./core/index.js",
      "require": "./core/index.cjs"
    },
    ".": {
      "@r-machine/source": "./src/lib/index.ts",
      "types": "./lib/index.d.cts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    },
    "./strategy": {
      "@r-machine/source": "./src/strategy/index.ts",
      "types": "./strategy/index.d.cts",
      "import": "./strategy/index.js",
      "require": "./strategy/index.cjs"
    },
    "./strategy/web": {
      "@r-machine/source": "./src/strategy/web/index.ts",
      "types": "./strategy/web/index.d.cts",
      "import": "./strategy/web/index.js",
      "require": "./strategy/web/index.cjs"
    }
  },
  "imports": {
    "#r-machine/errors": {
      "@r-machine/source": "./src/errors/index.ts",
      "types": "./errors/index.d.cts",
      "default": "./errors/index.js"
    },
    "#r-machine/locale": {
      "@r-machine/source": "./src/locale/index.ts",
      "types": "./locale/index.d.cts",
      "default": "./locale/index.js"
    },
    "#r-machine/core": {
      "@r-machine/source": "./src/core/index.ts",
      "types": "./core/index.d.cts",
      "default": "./core/index.js"
    },
    "#r-machine": {
      "@r-machine/source": "./src/lib/index.ts",
      "types": "./lib/index.d.cts",
      "default": "./lib/index.js"
    },
    "#r-machine/strategy": {
      "@r-machine/source": "./src/strategy/index.ts",
      "types": "./strategy/index.d.cts",
      "default": "./strategy/index.js"
    },
    "#r-machine/strategy/web": {
      "@r-machine/source": "./src/strategy/web/index.ts",
      "types": "./strategy/web/index.d.cts",
      "default": "./strategy/web/index.js"
    }
  },
  "scripts": {
    "clean": "git clean -xdf . -e node_modules",
    "build": "zshy --project tsconfig.build.json",
    "postbuild": "pnpm biome check --write .",
    "test": "pnpm vitest run --typecheck",
    "test:watch": "pnpm vitest watch --typecheck"
  }
}
