{
  "name": "@r-machine/next",
  "version": "1.0.0-alpha.14",
  "description": "Next.js App Router integration for R-Machine — typed resource layer with structural uniformity under change for Typescript.",
  "author": "Sergio Turolla <hello@codecarvings.com>",
  "license": "AGPL-3.0-only",
  "type": "module",
  "homepage": "https://rmachine.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecarvings/r-machine.git"
  },
  "bugs": "https://github.com/codecarvings/r-machine/issues",
  "keywords": [
    "rmachine",
    "typescript",
    "type-safe",
    "typesafe",
    "uniformity-under-change",
    "refactor-safe",
    "resource-layer",
    "i18n",
    "internationalization",
    "dependency-injection",
    "state-management",
    "reactive",
    "testable",
    "ai-friendly",
    "llm-friendly",
    "react",
    "nextjs",
    "no-codegen",
    "intellisense",
    "shell",
    "gear",
    "plug"
  ],
  "sideEffects": false,
  "files": [
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.d.ts",
    "**/*.d.mts",
    "**/*.d.cts"
  ],
  "main": "./lib/index.cjs",
  "types": "./lib/index.d.cts",
  "module": "./lib/index.js",
  "zshy": {
    "exports": {
      "./core": "./src/core/index.ts",
      "./app/flat": "./src/app/flat/index.ts",
      "./app/origin": "./src/app/origin/index.ts",
      "./app/path": "./src/app/path/index.ts",
      "./dev": "./src/dev/index.ts",
      "./dev/no-op": "./src/dev/no-op/index.ts",
      ".": "./src/lib/index.ts"
    },
    "conditions": {
      "@r-machine/source": "src"
    }
  },
  "exports": {
    "./core": {
      "@r-machine/source": "./src/core/index.ts",
      "types": "./core/index.d.cts",
      "import": "./core/index.js",
      "require": "./core/index.cjs"
    },
    "./app/flat": {
      "@r-machine/source": "./src/app/flat/index.ts",
      "types": "./app/flat/index.d.cts",
      "import": "./app/flat/index.js",
      "require": "./app/flat/index.cjs"
    },
    "./app/origin": {
      "@r-machine/source": "./src/app/origin/index.ts",
      "types": "./app/origin/index.d.cts",
      "import": "./app/origin/index.js",
      "require": "./app/origin/index.cjs"
    },
    "./app/path": {
      "@r-machine/source": "./src/app/path/index.ts",
      "types": "./app/path/index.d.cts",
      "import": "./app/path/index.js",
      "require": "./app/path/index.cjs"
    },
    "./dev": {
      "@r-machine/source": "./src/dev/index.ts",
      "types": "./dev/index.d.cts",
      "import": "./dev/index.js",
      "require": "./dev/index.cjs"
    },
    "./dev/no-op": {
      "@r-machine/source": "./src/dev/no-op/index.ts",
      "types": "./dev/no-op/index.d.cts",
      "import": "./dev/no-op/index.js",
      "require": "./dev/no-op/index.cjs"
    },
    ".": {
      "@r-machine/source": "./src/lib/index.ts",
      "types": "./lib/index.d.cts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "imports": {
    "#r-machine/next/internal": {
      "@r-machine/source": "./src/internal/index.ts",
      "types": "./internal/index.d.cts",
      "default": "./internal/index.js"
    },
    "#r-machine/next/core": {
      "@r-machine/source": "./src/core/index.ts",
      "types": "./core/index.d.cts",
      "default": "./core/index.js"
    },
    "#r-machine/next/core/app": {
      "@r-machine/source": "./src/core/app/index.ts",
      "types": "./core/app/index.d.cts",
      "default": "./core/app/index.js"
    },
    "#r-machine/next/core/app/flat": {
      "@r-machine/source": "./src/core/app/flat/index.ts",
      "types": "./core/app/flat/index.d.cts",
      "default": "./core/app/flat/index.js"
    },
    "#r-machine/next/core/app/origin": {
      "@r-machine/source": "./src/core/app/origin/index.ts",
      "types": "./core/app/origin/index.d.cts",
      "default": "./core/app/origin/index.js"
    },
    "#r-machine/next/core/app/path": {
      "@r-machine/source": "./src/core/app/path/index.ts",
      "types": "./core/app/path/index.d.cts",
      "default": "./core/app/path/index.js"
    },
    "#r-machine/next/errors": {
      "@r-machine/source": "./src/errors/index.ts",
      "types": "./errors/index.d.cts",
      "default": "./errors/index.js"
    },
    "#r-machine/next/app/flat": {
      "@r-machine/source": "./src/app/flat/index.ts",
      "types": "./app/flat/index.d.cts",
      "default": "./app/flat/index.js"
    },
    "#r-machine/next/app/origin": {
      "@r-machine/source": "./src/app/origin/index.ts",
      "types": "./app/origin/index.d.cts",
      "default": "./app/origin/index.js"
    },
    "#r-machine/next/app/path": {
      "@r-machine/source": "./src/app/path/index.ts",
      "types": "./app/path/index.d.cts",
      "default": "./app/path/index.js"
    },
    "#r-machine/next/dev": {
      "@r-machine/source": "./src/dev/index.ts",
      "types": "./dev/index.d.cts",
      "default": "./dev/index.js"
    },
    "#r-machine/next": {
      "@r-machine/source": "./src/lib/index.ts",
      "types": "./lib/index.d.cts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "clean": "git clean -xdf . -e node_modules",
    "build": "zshy --project tsconfig.build.json",
    "postbuild": "pnpm biome check --write .",
    "test": "pnpm vitest run --typecheck",
    "test:watch": "pnpm vitest watch --typecheck"
  },
  "peerDependencies": {
    "@r-machine/react": "workspace:*",
    "jiti": "^2",
    "next": "^15 || ^16",
    "r-machine": "workspace:*",
    "react": "^19"
  },
  "peerDependenciesMeta": {
    "jiti": {
      "optional": true
    }
  },
  "dependencies": {}
}
