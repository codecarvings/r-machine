{
  "name": "type-scale-bench",
  "version": "0.0.1-alpha.0",
  "private": true,
  "type": "module",
  "description": "Type-system scalability benchmark harness for R-Machine: generates realistic projects of growing size and measures tsc compile cost, type-trace hotspots and live tsserver IntelliSense latency.",
  "scripts": {
    "generate": "tsx src/generate.ts",
    "bench:compile": "tsx src/bench-compile.ts",
    "bench:intellisense": "tsx src/bench-intellisense.ts",
    "bench:trace": "tsx src/bench-trace.ts",
    "run-all": "tsx src/run-all.ts"
  },
  "dependencies": {
    "@r-machine/react": "workspace:*",
    "r-machine": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@typescript/analyze-trace": "^0.11.0",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  }
}
