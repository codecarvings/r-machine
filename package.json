{
  "private": true,
  "description": "Monorepo for R-Machine — a typed resource layer for TypeScript applications with first-class i18n support",
  "author": "Sergio Turolla <hello@codecarvings.com>",
  "type": "module",
  "homepage": "https://r-machine.codecarvings.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecarvings/r-machine.git"
  },
  "bugs": "https://github.com/codecarvings/r-machine/issues",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "check": "biome check --write .",
    "check:dry": "biome check .",
    "clean": "pnpm run -r clean",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "build:packages": "pnpm run -r --filter './packages/**' build",
    "build:examples": "pnpm run -r --filter './examples/**' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --coverage --open",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "size": "size-limit",
    "size:why": "size-limit --why --save-bundle ./size-limit",
    "prepare": "husky",
    "dev": "tsx --conditions @r-machine/source",
    "dev:play": "pnpm dev play.tsx",
    "changeset": "changeset",
    "__changeset:pre-enter-alpha": "changeset pre enter alpha",
    "__changeset:pre-exit": "changeset pre exit",
    "version-packages": "changeset version && pnpm check",
    "release": "pnpm build:packages && changeset publish"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": [
      "biome check --no-errors-on-unmatched --write"
    ],
    "packages/*/**/*.json": [
      "biome check --no-errors-on-unmatched --write"
    ],
    "packages/*/**/*.md": [
      "prettier --ignore-unknown --write"
    ]
  },
  "size-limit": [
    {
      "name": "r-machine",
      "path": "packages/r-machine/lib/index.js"
    },
    {
      "name": "@r-machine/react",
      "path": "packages/r-machine-react/lib/index.js",
      "ignore": [
        "r-machine",
        "react"
      ]
    },
    {
      "name": "r-machine/next - App flat strategy",
      "path": "packages/r-machine-next/app/flat/index.js",
      "ignore": [
        "r-machine",
        "@r-machine/react",
        "react",
        "next",
        "next/headers",
        "next/navigation",
        "next/server"
      ]
    },
    {
      "name": "r-machine/next - App origin strategy",
      "path": "packages/r-machine-next/app/origin/index.js",
      "ignore": [
        "r-machine",
        "@r-machine/react",
        "react",
        "next",
        "next/headers",
        "next/navigation",
        "next/server"
      ]
    },
    {
      "name": "r-machine/next - App path strategy",
      "path": "packages/r-machine-next/app/path/index.js",
      "ignore": [
        "r-machine",
        "@r-machine/react",
        "react",
        "next",
        "next/headers",
        "next/navigation",
        "next/server"
      ]
    }
  ],
  "pnpm": {
    "overrides": {
      "react": "19.2.6",
      "react-dom": "19.2.6"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.59.1",
    "@r-machine/next": "workspace:*",
    "@r-machine/react": "workspace:*",
    "@size-limit/esbuild-why": "^12.1.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.3",
    "next": "^16.2.6",
    "prettier": "^3.8.3",
    "r-machine": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "semver": "^7.7.4",
    "size-limit": "^12.1.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5",
    "zshy": "0.7.2"
  }
}
