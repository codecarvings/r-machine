{
  "private": true,
  "description": "Monorepo for R-Machine — a typed resource layer for TypeScript applications with first-class i18n support",
  "author": "Sergio Turolla <hello@codecarvings.com>",
  "type": "module",
  "homepage": "https://r-machine.codecarvings.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecarvings/r-machine.git"
  },
  "bugs": "https://github.com/codecarvings/r-machine/issues",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "check": "biome check --write .",
    "check:dry": "biome check .",
    "clean": "pnpm run -r clean",
    "build": "pnpm run -r build",
    "build:packages": "pnpm run -r --filter './packages/**' build",
    "build:examples": "pnpm run -r --filter './examples/**' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --coverage --open",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "prepare": "husky",
    "dev": "tsx --conditions @r-machine/source",
    "dev:play": "pnpm dev play.tsx",
    "changeset": "changeset",
    "__changeset:pre-enter-alpha": "changeset pre enter alpha",
    "__changeset:pre-exit": "changeset pre exit",
    "version-packages": "changeset version && pnpm check",
    "release": "pnpm build:packages && changeset publish"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": [
      "biome check --no-errors-on-unmatched --write"
    ],
    "packages/*/**/*.json": [
      "biome check --no-errors-on-unmatched --write"
    ],
    "packages/*/**/*.md": [
      "prettier --ignore-unknown --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.58.2",
    "@r-machine/next": "workspace:*",
    "@r-machine/react": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "husky": "9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "next": "^16.2.0",
    "prettier": "^3.8.1",
    "r-machine": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semver": "^7.7.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0",
    "zshy": "0.7.0"
  }
}
